{
  "name": "quartz-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ui/quartz-ui/src",
  "projectType": "library",
  "tags": ["type:ui", "scope:shared"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/ui/quartz-ui"],
      "dependsOn": ["^build"],
      "options": {
        "parallel": false,
        "commands": [
          "mkdir -p dist/libs/ui/quartz-ui/src/lib",
          "npx tsc -p libs/ui/quartz-ui/tsconfig.lib.json --outDir dist/libs/ui/quartz-ui",
          "cp libs/ui/quartz-ui/package.json dist/libs/ui/quartz-ui/package.json",
          "cp libs/ui/quartz-ui/README.md dist/libs/ui/quartz-ui/README.md",
          "cp -R libs/ui/quartz-ui/src/lib dist/libs/ui/quartz-ui/src/lib"
        ]
      }
    },
    "publish": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public --otp=$NPM_OTP",
        "cwd": "dist/libs/ui/quartz-ui"
      }
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["^nx-release-publish"]
    }
  }
}
