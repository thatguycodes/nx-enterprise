{
  "name": "tokens",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/tokens/src",
  "projectType": "library",
  "tags": ["type:tokens", "scope:shared"],
  "// targets": "to see all targets run: nx show project tokens --web",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ts-node -T libs/shared/tokens/scripts/build-tokens.ts"
      },
      "configurations": {},
      "parallelism": true
    },
    "publish": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public --otp=$NPM_OTP",
        "cwd": "libs/shared/tokens"
      },
      "configurations": {},
      "parallelism": true
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["^nx-release-publish"],
      "options": {},
      "configurations": {},
      "parallelism": true
    }
  }
}
