{
  "name": "design-tokens",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/tokens/design-tokens/src",
  "projectType": "library",
  "tags": ["type:tokens", "scope:shared"],
  "// targets": "to see all targets run: nx show project design-tokens --web",
  "targets": {
    "transform": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node libs/tokens/design-tokens/scripts/transform-figma-tokens.mjs"
      }
    },
    "generate": {
      "dependsOn": ["transform"],
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf libs/tokens/design-tokens/src/generated/css libs/tokens/design-tokens/src/generated/ts && node libs/tokens/design-tokens/scripts/build-tokens.mjs"
      }
    },
    "build": {
      "dependsOn": ["generate"],
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/tokens/design-tokens",
        "main": "libs/tokens/design-tokens/src/index.ts",
        "tsConfig": "libs/tokens/design-tokens/tsconfig.lib.json",
        "assets": [
          "libs/tokens/design-tokens/README.md",
          {
            "input": "libs/tokens/design-tokens",
            "glob": "package.json",
            "output": "."
          },
          {
            "input": "libs/tokens/design-tokens/src/generated/css",
            "glob": "*.css",
            "output": "generated/css"
          }
        ]
      },
      "configurations": {},
      "parallelism": false
    },
    "publish": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public --otp=$NPM_OTP",
        "cwd": "dist/libs/tokens/design-tokens"
      },
      "configurations": {},
      "parallelism": true
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["^nx-release-publish"],
      "options": {},
      "configurations": {},
      "parallelism": true
    }
  }
}
