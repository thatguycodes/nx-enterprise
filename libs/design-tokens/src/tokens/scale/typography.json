{
  "scale": {
    "typography": {
      "size": {
        "xs":   { "$type": "dimension", "$value": "{typography.size.xs}" },
        "sm":   { "$type": "dimension", "$value": "{typography.size.sm}" },
        "base": { "$type": "dimension", "$value": "{typography.size.base}" },
        "lg":   { "$type": "dimension", "$value": "{typography.size.lg}" },
        "xl":   { "$type": "dimension", "$value": "{typography.size.xl}" },
        "2xl":  { "$type": "dimension", "$value": "{typography.size.2xl}" },
        "3xl":  { "$type": "dimension", "$value": "{typography.size.3xl}" },
        "4xl":  { "$type": "dimension", "$value": "{typography.size.4xl}" }
      },
      "weight": {
        "regular":  { "$type": "number", "$value": "{typography.weight.regular}" },
        "medium":   { "$type": "number", "$value": "{typography.weight.medium}" },
        "semibold": { "$type": "number", "$value": "{typography.weight.semibold}" },
        "bold":     { "$type": "number", "$value": "{typography.weight.bold}" }
      }
    }
  }
}
