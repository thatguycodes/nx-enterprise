{
  "color": {
    "brand": {
      "200": { "$type": "color", "$value": "{scale.color.brand.200}" },
      "300": { "$type": "color", "$value": "{scale.color.brand.300}" }
    },
    "surface": {
      "$description": "Consumed by Card, Modal, Page",
      "page":    { "$type": "color", "$value": "{scale.color.neutral.50}",  "$description": "Main page/app background" },
      "default": { "$type": "color", "$value": "{scale.color.neutral.100}", "$description": "Card and panel background" },
      "raised":  { "$type": "color", "$value": "#FFFFFF",                   "$description": "Elevated surfaces (modals, popovers)" },
      "sunken":  { "$type": "color", "$value": "{scale.color.neutral.200}", "$description": "Input backgrounds, inset areas" },
      "overlay": { "$type": "color", "$value": "#FFFFFF",                   "$description": "Overlay/modal backdrop base" }
    },
    "text": {
      "$description": "Consumed by Typography, labels",
      "primary":     { "$type": "color", "$value": "{scale.color.neutral.900}", "$description": "Primary text" },
      "secondary":   { "$type": "color", "$value": "{scale.color.neutral.600}", "$description": "Secondary / muted text" },
      "placeholder": { "$type": "color", "$value": "{scale.color.neutral.400}", "$description": "Placeholder text" },
      "disabled":    { "$type": "color", "$value": "{scale.color.neutral.300}", "$description": "Disabled text" },
      "on-brand":    { "$type": "color", "$value": "#FFFFFF",                   "$description": "Text on amber action backgrounds" },
      "on-surface":  { "$type": "color", "$value": "{scale.color.neutral.900}", "$description": "Text on default surfaces" }
    },
    "border": {
      "$description": "Consumed by Input, Divider",
      "default":  { "$type": "color", "$value": "{scale.color.neutral.200}", "$description": "Default border for inputs and panels" },
      "strong":   { "$type": "color", "$value": "{scale.color.neutral.300}", "$description": "Stronger border for emphasis" },
      "focus":    { "$type": "color", "$value": "{scale.color.brand.500}",   "$description": "Focus ring color for interactive elements" },
      "error":    { "$type": "color", "$value": "{scale.color.feedback.error}", "$description": "Error state border" },
      "disabled": { "$type": "color", "$value": "{scale.color.neutral.100}", "$description": "Disabled border color" }
    },
    "action": {
      "$description": "Consumed by Button, FAB, links",
      "bg-default":    { "$type": "color", "$value": "{scale.color.brand.500}", "$description": "Primary action background" },
      "bg-hover":      { "$type": "color", "$value": "{scale.color.brand.600}", "$description": "Hover action background" },
      "bg-pressed":    { "$type": "color", "$value": "{scale.color.brand.700}", "$description": "Pressed/active action background" },
      "bg-disabled":   { "$type": "color", "$value": "{scale.color.neutral.200}", "$description": "Disabled action background" },
      "text":          { "$type": "color", "$value": "#FFFFFF", "$description": "Text on primary action backgrounds" },
      "text-disabled": { "$type": "color", "$value": "{scale.color.neutral.400}", "$description": "Disabled action text" }
    },
    "feedback": {
      "$description": "Consumed by Alert, Toast, Badge",
      "error":   { "$type": "color", "$value": "{scale.color.feedback.error}" },
      "warning": { "$type": "color", "$value": "{scale.color.feedback.warning}" },
      "success": { "$type": "color", "$value": "{scale.color.feedback.success}" },
      "info":    { "$type": "color", "$value": "{scale.color.feedback.info}" }
    }
  },
  "spacing": {
    "2xs": { "$type": "dimension", "$value": "{scale.spacing.2xs}" },
    "xs":  { "$type": "dimension", "$value": "{scale.spacing.xs}" },
    "sm":  { "$type": "dimension", "$value": "{scale.spacing.sm}" },
    "md":  { "$type": "dimension", "$value": "{scale.spacing.md}" },
    "lg":  { "$type": "dimension", "$value": "{scale.spacing.lg}" },
    "xl":  { "$type": "dimension", "$value": "{scale.spacing.xl}" },
    "2xl": { "$type": "dimension", "$value": "{scale.spacing.2xl}" },
    "3xl": { "$type": "dimension", "$value": "{scale.spacing.3xl}" }
  }
}
