# Environment Variables Template
# Copy this file to .env.local and fill in your local values
#
# IMPORTANT: .env.local is ignored by git and should NEVER be committed
# This file (.env.example) shows the structure without actual values

# ============================================================================
# FIGMA TOKEN SYNC
# ============================================================================
# Figma Token Sync Configuration
# Visit https://www.figma.com/settings to create your personal access token
FIGMA_ACCESS_TOKEN=your_figma_access_token_here

# Your Figma design file ID
# Found in Figma file URL: figma.com/file/{FILE_ID}/...
FIGMA_FILE_ID=your_figma_file_id_here

# ============================================================================
# GITHUB & SEMANTIC RELEASE
# ============================================================================
# GitHub Personal Access Token for semantic-release
# Create at: https://github.com/settings/tokens
# Scopes: repo, workflow, packages
ADMIN_ACCESS_TOKEN=your_github_admin_token_here

# ============================================================================
# NPM PUBLISHING
# ============================================================================
# NPM Authentication Token for publishing packages
# Create at: https://www.npmjs.com/settings/~/tokens
# Type: Automation token (recommended)
NPM_TOKEN=your_npm_token_here

# ============================================================================
# GIT COMMIT SIGNING (GPG)
# ============================================================================
# GPG Private Key for signing commits
# Generate: gpg --full-generate-key
# Export: gpg --armor --export-secret-keys {KEY_ID} > private-key.asc
GPG_PRIVATE_KEY=your_gpg_private_key_here

# GPG Passphrase for the private key
GPG_PASSPHRASE=your_gpg_passphrase_here

# Email for git commits (used by semantic-release)
# Should match your git config email
GIT_COMMITTER_EMAIL=your_email@example.com

# ============================================================================
# Optional Development Secrets
# ============================================================================
# Add any other environment variables your local development needs below
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
# API_KEY=your_api_key_here
# NODE_ENV=development

